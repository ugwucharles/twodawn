{
    "$schema": "https://json.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "setup": "node setup.js",
        "setup:vercel": "node scripts/setup-vercel-env.cjs",
        "build": "npm run build --prefix frontend",
        "node:dev": "node --dns-result-order=ipv4first node-app/server.cjs",
        "frontend:dev": "npm run dev --prefix frontend",
        "dev": "concurrently \"npm run node:dev\" \"npm run frontend:dev\"",
        "vercel:sync-env": "node scripts/sync-env.cjs"
    },
    "devDependencies": {
        "@tailwindcss/forms": "^0.5.2",
        "@tailwindcss/vite": "^4.0.0",
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "@vitejs/plugin-react": "^4.7.0",
        "alpinejs": "^3.4.2",
        "autoprefixer": "^10.4.2",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "postcss": "^8.4.31",
        "tailwindcss": "^3.1.0",
        "vite": "^7.0.7"
    },
    "dependencies": {
        "@libsql/client": "^0.17.4",
        "@react-oauth/google": "^0.13.5",
        "bcryptjs": "^2.4.3",
        "better-sqlite3": "^12.11.1",
        "chart.js": "^4.5.0",
        "cloudinary": "^1.41.3",
        "express": "^4.21.2",
        "lucide-react": "^1.21.0",
        "multer": "^2.2.0",
        "multer-storage-cloudinary": "^4.0.0",
        "mysql2": "^3.15.3",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-router-dom": "^6.20.0",
        "zustand": "^4.4.0"
    }
}
