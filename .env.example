APP_NAME=2DAWN
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=https://example.com
FORCE_HTTPS=true

# Vercel Deployment
# When deploying to Vercel, set these environment variables in your Vercel project settings
# VERCEL_URL will be automatically set by Vercel

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# For Vercel deployment, use 'public' or configure Cloudinary/S3
# FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# Options: smtp, resend, sendgrid, log
MAIL_MAILER=smtp
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=YOUR_SENDGRID_API_KEY
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=info@example.com
MAIL_FROM_NAME="2DAWN"

# API Email Drivers (for 'resend' or 'sendgrid' mailer options)
RESEND_API_KEY=
SENDGRID_API_KEY=



# Paystack
PAYSTACK_PUBLIC_KEY=YOUR_PAYSTACK_PUBLIC_KEY
PAYSTACK_SECRET_KEY=YOUR_PAYSTACK_SECRET_KEY
PAYSTACK_CALLBACK_URL="https://YOUR_DOMAIN/paystack/callback"

# Cloudflare Turnstile (optional; enables bot check for free orders)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Secondary SMTPs for round-robin (optional)
SMTP1_USERNAME=
SMTP1_PASSWORD=
SMTP2_USERNAME=
SMTP2_PASSWORD=

# Seed a default admin on first boot (optional)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Host Panel test (local only)
HOST_TEST_REFERENCE=PA_ab12cd34ef56

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Google OAuth (Sign in with Google)
GOOGLE_CLIENT_ID=374153756599-htfh4m0oit0obnb3ehj548infilmt997.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID="${GOOGLE_CLIENT_ID}"

# Frontend error tracking (Sentry Browser SDK)
SENTRY_JS_DSN=

# Cloudinary (optional)
# Either use the single URL or the three separate keys
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Analytics/Search (optional)
# Set ONE of the following
GA_MEASUREMENT_ID=
PLAUSIBLE_DOMAIN=
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# Queues
ENABLE_QUEUE_WORKER=1
ENABLE_SCHEDULER=1

